# Copy to backend/.env for local (non-Replit) use, or set these as Replit Secrets.
# On Replit: MONGO_URL and JWT_SECRET are managed via the Secrets pane (requestSecrets),
# never committed here with real values.

# MongoDB Atlas connection string, e.g. mongodb+srv://user:pass@cluster.mongodb.net
MONGO_URL=

# Database name (non-secret; also set as a shared Replit env var)
DB_NAME=skyhawk_ops

# Secret used to sign JWT auth tokens (any long random string)
JWT_SECRET=

# Optional
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# Optional push notification key; backend falls back gracefully if missing
EMERGENT_PUSH_KEY=
