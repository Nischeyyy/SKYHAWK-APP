modules = ["nodejs-20", "python-3.12", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[userenv]

[userenv.shared]
DB_NAME = "skyhawk_ops"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Go"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Manager Portal"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PATH=$HOME/.pythonlibs/bin:$PATH uvicorn server:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node proxy.js & cd frontend && bash start.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "Expo Go"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && EXPO_PUBLIC_BACKEND_URL=https://$REPLIT_DEV_DOMAIN ./node_modules/.bin/expo start --tunnel --port 8099"
waitForPort = 8099

[[workflows.workflow]]
name = "Manager Portal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd manager-portal && npm run build && node serve.cjs"
waitForPort = 8081

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8099
externalPort = 8099

[deployment]
deploymentTarget = "cloudrun"
